
<!-- <input type="hidden" name="facility" value="< %= facility._id % >"> -->
<div class="form-row">
  <div class="form-item">
    <label>Date</label>
    <input type="date" name="date" value="<%= data?.date %>" required oninput="fetchAvailableTables()" autocomplete="off">
  </div>
  <div class="form-item">
    <label>Time</label>
    <input type="time" name="time" value="<%= data?.time %>" min="12:00" max="22:00" required oninput="fetchAvailableTables()" autocomplete="off">
  </div>
  <div class="form-item">
    <label>Seats</label>
    <input type="number" name="seats" value="<%= data?.seats %>" min="2" required oninput="renderAvailableTables()" autocomplete="off">
  </div>
  
</div>
<div class="form-row">
  <div class="form-item no-grow">
    <label>Adjust</label>
    <input type="number" name="adjust" placeholder="time adjustment in minutes" pattern="-?[0-9]+" value="<%= locals.adjust ?? 0 %>"
      step="15" oninput="renderAdjustedTime(); fetchAvailableTables()">
  </div>
  <div class="form-item">
    <label>Adjusted time:</label>
    <div id="adjusted-time"><%= data?.time %></div>
  </div>
</div>

<h3>Available Tables</h3>
<div class="available-tables"></div>
<div class="total-seats">Total seats: <span id="total-seats">0</span></div>


<div class="form-row">
  <div class="form-item">
    <label>Name</label>
    <input type="text" name="name" value="<%= data?.name %>" required autocomplete="off">
  </div>
  
</div>

<div class="form-row">
  <div class="form-item">
    <label>Phone</label>
    <input type="tel" name="phone" value="<%= data?.phone %>" required autocomplete="off">
  </div>
</div>
