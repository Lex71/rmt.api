<div class="form-row form-row-end">
  <a class="btn btn-primary" href="/reservations/new">Add Reservation</a>
</div>
<h2 class="page-header">Search Reservations</h2>
<form action="/reservations" method="GET">
  <div class="form-row">
    <div class="form-item">
      <label>Date</label>
      <input type="date" name="date" value="<%= searchOptions?.date %>">
    </div>
    <div class="form-item">
      <label>Name</label>
      <input type="text" name="name" value="<%= searchOptions?.name %>">
    </div>
    <div class="form-item">
      <label>Phone</label>
      <input type="tel" name="tel" value="<%= searchOptions?.phone %>">
    </div>
  </div>
  <div class="form-row form-row-end">
    <button class="btn btn-primary" type="submit">Search</button>
  </div>
</form>
<br />
<% data.forEach(item=> { %>
  <div class="table-details">
    <div class="table-date">
      <%= item.date %>, <%= item.time %>
    </div>
    <div class="table-name">
      <%= item.name %>
    </div>
    <div class="table-status">
      <%= item.status %>
    </div>
    <div class="btn-row">
      <a class="btn btn-primary" href="/reservations/<%= item._id %>">View</a>
      <a class="btn btn-primary" href="/reservations/<%= item._id %>/edit">Edit</a>
      <%- include('../partials/deleteForm', { url: `/reservations/${item._id}` }) %>
      <!-- <a class="btn btn-form btn-small" href="/reservations/< %= item._id %>/cancelled">Cancel</a>
      <a class="btn btn-form btn-small" href="/reservations/< %= item._id %>/checkedin">Checked In</a>
      <a class="btn btn-form btn-small" href="/reservations/< %= item._id %>/noshow">No Show</a>
      <a class="btn btn-form btn-small" href="/reservations/< %= item._id %>/paid">Paid</a> -->
      <%- include('../partials/singleFieldForm', { url: `/reservations/${item._id}`, name: "status", type: "text", label: "Cancelled", method: "PATCH", value: "cancelled" }) %>
      <%- include('../partials/singleFieldForm', { url: `/reservations/${item._id}`, name: "status", type: "text", label: "Checked In", method: "PATCH", value: "checkedin" }) %>
      <%- include('../partials/singleFieldForm', { url: `/reservations/${item._id}`, name: "status", type: "text", label: "No Show", method: "PATCH", value: "noshow" }) %>
      <%- include('../partials/singleFieldForm', { url: `/reservations/${item._id}`, name: "status", type: "text", label: "Paid", method: "PATCH", value: "paid" }) %>
    </div>
  </div>
  <% }) %>

<script>
  document.addEventListener("DOMContentLoaded", function () {
      if (document.querySelector('input[name="date"]').value == "") {
        document.querySelector('input[name="date"]').value =
          moment().format("YYYY-MM-DD");
      }
    });
</script>