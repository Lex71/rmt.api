<div class="form-row">
  <div class="form-item">
    <label for="email">Email</label>
    <input type="email" id="email" name="email" required value="<%= locals.data ? data.user?.email : null %>" autocomplete="off">
  </div>
</div>
<div class=" form-row">
  <div class="form-item">
    <label for="password">Password</label>
    <input type="password" id="password" name="password" required  autocomplete="new-password">
  </div>
</div>