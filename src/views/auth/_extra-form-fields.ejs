<div class="form-row">
  <div class="form-item">
    <label for="name">Name</label>
    <input type="text" id="name" name="name" required value="" autocomplete="new-name">
  </div>
</div>
<div class="form-row">
  <div class="form-item">
    <label for="name">Facility</label>
    <select name="facility" required>
      <% data?.facilities.forEach(facility=> { %>
        <option label="<%= facility.name %>" value="<%= facility._id %>"></option>
      <% }) %>
    </select>
  </div>
</div>
